{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PilotBell",
  "version": "0.2.0",
  "identifier": "io.github.fouri7.pilotbell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PilotBell",
        "center": true,
        "width": 980,
        "height": 760,
        "minWidth": 360,
        "minHeight": 420,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "4i7",
    "homepage": "https://github.com/4i7/PilotBell",
    "copyright": "Copyright (c) 2026 4i7",
    "category": "Productivity",
    "shortDescription": "A Rust-native document processing desktop tool.",
    "longDescription": "PilotBell is a Rust-native desktop tool for fast local PDF and Excel analysis, reviewable Markdown and SVG output, and DOCX report generation with optional LLM assistance.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"],
        "displayLanguageSelector": false,
        "startMenuFolder": "PilotBell",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
